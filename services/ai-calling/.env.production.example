# Production Environment Variables
# Copy this to .env.production and fill in real values

# Server
PORT=8080
NODE_ENV=production

# Database (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Providers
OPENAI_API_KEY=sk-prod-...
GEMINI_API_KEY=AIzaSy...
DEEPGRAM_API_KEY=...
ELEVENLABS_API_KEY=...

# Telephony
TWILIO_ACCOUNT_SID=...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=...

# Security
JWT_SECRET=complex_production_secret_key
CORS_ORIGIN=https://app.dentacor.com
