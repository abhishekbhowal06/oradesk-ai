# ===========================================
# AI CALLING SERVICE - ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ===========================================

# --- Twilio ---
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# --- LLM / AI ---
PRIMARY_LLM_API_KEY=""
GEMINI_API_KEY=""
FALLBACK_LLM_API_KEY=""

# --- Supabase (Backend - Service Role) ---
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""

# --- Speech ---
DEEPGRAM_API_KEY=""
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID="21m00Tcm4TlvDq8ikWAM"  # Rachel (warm female). Override for A/B testing.
OPENAI_API_KEY=""

# --- Server ---
PORT=3000
SERVICE_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:8085"

# --- Feature Flags ---
REALTIME_MODE=true
STREAMING_ENABLED=true
